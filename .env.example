# Discord webhook URL for the results channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google account for automated sign-in to zwiftracing.app.
# GOOGLE_EMAIL selects your account on Google's account-chooser screen.
# GOOGLE_PASSWORD is optional and only used if the Edge profile has no
# active Google session; Google may refuse password entry from automated
# browsers, in which case the script falls back to a one-time manual login.
GOOGLE_EMAIL=you@example.com
#GOOGLE_PASSWORD=
